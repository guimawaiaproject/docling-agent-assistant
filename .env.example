# Docling v3 — Variables d'environnement
# cp .env.example .env  puis renseigner

# --- Requis ---
GEMINI_API_KEY=
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
JWT_SECRET=

# --- Dev (accès sans login) ---
ENVIRONMENT=development
FREE_ACCESS_MODE=false

# --- Optionnel ---
# BYTEZ_API_KEY=
# WATCHDOG_FOLDER=./Docling_Factures
# STORJ_BUCKET=docling-factures
# PWA_URL=https://docling-agent.netlify.app
# SENTRY_DSN=
# COMMUNITY_SALT=

# --- Frontend (VITE_) ---
VITE_API_URL=http://localhost:8000
VITE_AUTH_REQUIRED=false
VITE_SENTRY_DSN=
